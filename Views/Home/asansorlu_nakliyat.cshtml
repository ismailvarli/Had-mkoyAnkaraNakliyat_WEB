<script>
  (function () {
    const headerVar = getComputedStyle(document.documentElement).getPropertyValue('--header-height') || '80px';
    const headerH = (headerVar.replace('px','')*1) || 80;

    document.querySelectorAll('.toc a[href^="#"]').forEach(a => {
      a.addEventListener('click', function (e) {
        e.preventDefault();
        const id = this.getAttribute('href').slice(1);
        const target = document.getElementById(id);
        if (!target) return;
        const y = window.scrollY + target.getBoundingClientRect().top - headerH - 16;
        window.scrollTo({ top: y, behavior: 'smooth' });
      });
    });

    const map = {};
    document.querySelectorAll('.toc a[href^="#"]').forEach(a => { map[a.getAttribute('href').slice(1)] = a; });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const id = entry.target.id;
        const link = map[id];
        if (!link) return;
        if (entry.isIntersecting) {
          document.querySelectorAll('.toc a').forEach(x => x.classList.remove('is-active'));
          link.classList.add('is-active');
        }
      });
    }, { rootMargin: `-${headerH + 24}px 0px -70% 0px`, threshold: 0.1 });

    Object.keys(map).forEach(id => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  })();
</script>
