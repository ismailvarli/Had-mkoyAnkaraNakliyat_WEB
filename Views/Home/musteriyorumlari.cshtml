        gap: 14px;
        margin-bottom: 14px;
    }
    .review-avatar {
        width: 46px; height: 46px;
        background: #ff7300;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-weight: 700; font-size: 18px;
    }
    .review-author { font-weight: 700; color: #2c3e50; font-size: 15px; }
    .review-date { font-size: 12px; color: #999; }
    .review-stars { color: #fbbc05; font-size: 16px; margin-bottom: 8px; }
    .review-text { color: #555; font-size: 14px; line-height: 1.7; margin: 0; }
    .google-cta-box {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 40px;
        text-align: center;
        max-width: 700px;
        margin: 40px auto 60px;
    }
    .google-cta-box h2 { color: #2c3e50; margin-bottom: 12px; }
    .google-cta-box p { color: #666; margin-bottom: 24px; }
    .btn-google-review {
