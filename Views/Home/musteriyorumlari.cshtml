        text-align: center;
    }
    .review-page-hero h1 { font-size: 2rem; margin-bottom: 10px; }
    .review-page-hero p { font-size: 1.1rem; opacity: .9; }
    .rating-summary {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,.1);
        padding: 30px;
        max-width: 480px;
        margin: -30px auto 0;
        text-align: center;
    }
    .rating-big { font-size: 3.5rem; font-weight: 800; color: #ff7300; line-height: 1; }
    .stars-big { font-size: 28px; color: #fbbc05; margin: 6px 0; }
    .rating-count { color: #888; font-size: 14px; }
    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
        max-width: 1100px;
        margin: 50px auto;
        padding: 0 20px;
    }
    .review-card {
        background: #fff;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,.08);
        border-left: 4px solid #ff7300;
    }
    .review-card-header {
