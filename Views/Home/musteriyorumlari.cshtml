<style>
    .review-page-hero {
        background: linear-gradient(135deg, #ff7300 0%, #e65c00 100%);
        color: #fff;
        padding: 60px 0 40px;
        text-align: center;
    }
    .review-page-hero h1 { font-size: 2rem; margin-bottom: 10px; }
    .review-page-hero p { font-size: 1.1rem; opacity: .9; }
    .rating-summary {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,.1);
        padding: 30px;
        max-width: 480px;
        margin: -30px auto 0;
        text-align: center;
    }
    .rating-big { font-size: 3.5rem; font-weight: 800; color: #ff7300; line-height: 1; }
    .stars-big { font-size: 28px; color: #fbbc05; margin: 6px 0; }
    .rating-count { color: #888; font-size: 14px; }
    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 24px;
        max-width: 1100px;
        margin: 50px auto;
        padding: 0 20px;
    }
    .review-card {
        background: #fff;
        border-radius: 12px;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,.08);
        border-left: 4px solid #ff7300;
    }
    .review-card-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 14px;
    }
    .review-avatar {
        width: 46px; height: 46px;
        background: #ff7300;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-weight: 700; font-size: 18px;
    }
    .review-author { font-weight: 700; color: #2c3e50; font-size: 15px; }
    .review-date { font-size: 12px; color: #999; }
    .review-stars { color: #fbbc05; font-size: 16px; margin-bottom: 8px; }
    .review-text { color: #555; font-size: 14px; line-height: 1.7; margin: 0; }
    .google-cta-box {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 40px;
        text-align: center;
        max-width: 700px;
        margin: 40px auto 60px;
    }
    .google-cta-box h2 { color: #2c3e50; margin-bottom: 12px; }
    .google-cta-box p { color: #666; margin-bottom: 24px; }
    .btn-google-review {
        display: inline-flex; align-items: center; gap: 10px;
        background: #fff; color: #3c4043; border: 2px solid #dadce0;
        border-radius: 8px; padding: 14px 28px;
        font-size: 16px; font-weight: 700; text-decoration: none;
        box-shadow: 0 2px 8px rgba(0,0,0,.12);
        transition: box-shadow .2s;
    }
    .btn-google-review:hover { box-shadow: 0 4px 16px rgba(0,0,0,.2); color: #3c4043; }
</style>

