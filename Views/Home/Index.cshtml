@{
    ViewData["Title"] = "Hadımköy Ankara Nakliyat | İstanbul Ankara Arası Profesyonel Taşımacılık";
    ViewData["Description"] = "İstanbul ve Ankara arasında evden eve, ofis, çeyiz, fuar, ambar ve parsiyel taşımacılıkta 7/24 hizmet. Ücretsiz ekspertiz ve sürprizsiz fiyat Hadımköy Ankara Nakliyat'ta!";

    var homeSchema = @"{
      ""@context"": ""https://schema.org"",
      ""@type"": ""WebSite"",
      ""name"": ""Hadımköy Ankara Nakliyat"",
      ""url"": ""https://www.hadimkoyankaranakliyat.com/"",
      ""potentialAction"": {
        ""@type"": ""SearchAction"",
        ""target"": ""https://www.hadimkoyankaranakliyat.com/search?q={search_term_string}"",
        ""query-input"": ""required name=search_term_string""
      }
    }";

    var homeServiceSchema = @"{
      ""@context"": ""https://schema.org"",
      ""@type"": ""Service"",
      ""name"": ""İstanbul Ankara Nakliyat Hizmetleri"",
      ""provider"": { ""@type"": ""LocalBusiness"", ""name"": ""Hadımköy Ankara Nakliyat"" },
      ""areaServed"": [""İstanbul"", ""Ankara"", ""Türkiye""],
      ""description"": ""İstanbul ve Ankara merkezli, 81 ile sigortalı, asansörlü ve kurumsal evden eve nakliyat, ofis taşıma ve parsiyel yük taşımacılığı.""
    }";
}
<script type="application/ld+json">@Html.Raw(homeSchema)</script>
<script type="application/ld+json">@Html.Raw(homeServiceSchema)</script>
<script type="application/ld+json">
{
  "@@context": "https://schema.org",
  "@@type": "FAQPage",
  "mainEntity": [
    {
      "@@type": "Question",
      "name": "İstanbul-Ankara arası nakliyat ne kadar sürer?",
      "acceptedAnswer": {
        "@@type": "Answer",
        "text": "İstanbul'dan Ankara'ya mesafe yaklaşık 450 km'dir. Standart koşullarda taşıma süresi 5-7 saattir. Hadımköy Ankara Nakliyat olarak haftanın 6 günü düzenli sefer düzenliyor, eşyalarınızı günü gününe teslim ediyoruz."
      }
    },
    {
      "@@type": "Question",
      "name": "Evden eve nakliyatta hangi hizmetler dahil?",
      "acceptedAnswer": {
        "@@type": "Answer",
        "text": "Evden eve nakliyat hizmetimizde eşya paketleme, asansörlü taşıma, marangoz demontaj/montaj ve özel ambalaj dahildir. Sigortalı taşıma seçeneğiyle eşyalarınız güvence altındadır."
      }
    },
    {
      "@@type": "Question",
      "name": "Parsiyel nakliyat ne zaman tercih edilmeli?",
      "acceptedAnswer": {
        "@@type": "Answer",
        "text": "Parsiyel nakliyat, 1-2 oda eşyası ya da birkaç koli gibi az hacimli taşımalar için idealdir. Tam araç kiralamak yerine paylaşımlı yükle çok daha uygun maliyetli taşıma imkânı sunar."
      }
    },
    {
      "@@type": "Question",
      "name": "İstanbul-Ankara nakliyat fiyatları 2026'da ne kadar?",
      "acceptedAnswer": {
        "@@type": "Answer",
        "text": "2026 yılında İstanbul-Ankara arası evden eve nakliyat fiyatları; 1+1 daire için 8.000–14.000 ₺, 2+1 için 13.000–22.000 ₺, 3+1 için 20.000–32.000 ₺ aralığındadır. Kesin fiyat eşya miktarı, kat bilgisi ve asansör durumuna göre belirlenir."
      }
    },
    {
      "@@type": "Question",
      "name": "Eşya depolama hizmeti sunuyor musunuz?",
      "acceptedAnswer": {
        "@@type": "Answer",
        "text": "Evet. Klimatize depolarımızda günlük, haftalık veya aylık eşya depolama hizmeti sunuyoruz. 7/24 kamera güvenliği ve sigorta güvencesiyle eşyalarınız tam koruma altında. Taşıma ve depolama tek çatı altında, çift nakliye ücreti ödemezsiniz."
      }
    },
    {
      "@@type": "Question",
      "name": "Nakliyat sigortası neden önemlidir?",
      "acceptedAnswer": {
        "@@type": "Answer",
        "text": "Nakliyat sigortası, taşıma sırasında oluşabilecek hasar, kırık veya kayıp durumunda tazminat güvencesi sağlar. Uzun mesafeli İstanbul-Ankara taşımalarında yol koşulları ve yükleme riski nedeniyle sigorta yaptırmanızı şiddetle tavsiye ederiz."
      }
    },
    {
      "@@type": "Question",
      "name": "Taşınma günü hazırlıkları nasıl yapılmalıdır?",
      "acceptedAnswer": {
        "@@type": "Answer",
        "text": "Taşınma gününden en az 1 hafta önce kolileri hazırlayın, kırılgan eşyaları ayrı işaretleyin. Elektrikli aletlerin kablolarını bağlayın. Değerli evrak ve takıları kendiniz taşıyın. Ekibimiz geldiğinde apartman yöneticisini bilgilendirin, asansörü rezerve edin."
      }
    }
  ]
}
</script>
