    .han-intro__features { grid-template-columns: 1fr; }
    .han-intro__img-area { margin-top: 40px; }
    .han-intro__img-area img { height: 260px; }
}

/* ===== KAYAN İLÇE KARTLARI ===== */
.han-scroll-section {
    padding: 60px 0;
    background: #f8f9fa;
    overflow: hidden;
}
.han-scroll-section__header {
    text-align: center;
    margin-bottom: 36px;
}
.han-scroll-section__header h2 { font-size: 28px; font-weight: 800; color: #1a1a2e; margin-bottom: 8px; }
.han-scroll-section__header p { color: #6c757d; font-size: 15px; }
.han-scroll-row { overflow: hidden; margin-bottom: 14px; }
.han-scroll-track {
    display: flex;
    gap: 14px;
    width: max-content;
    animation: han-ltr 50s linear infinite;
}
.han-scroll-track.reverse { animation: han-rtl 50s linear infinite; }
.han-scroll-track:hover, .han-scroll-track.reverse:hover { animation-play-state: paused; }
@@keyframes han-ltr { from { transform: translateX(0); } to { transform: translateX(-50%); } }
@@keyframes han-rtl { from { transform: translateX(-50%); } to { transform: translateX(0); } }

/* İlçe Kartı — servis kartı stilinde */
.han-ilce-card {
    display: block;
    width: 185px;
    flex-shrink: 0;
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 3px 12px rgba(0,0,0,.08);
    text-decoration: none;
    color: inherit;
    transition: transform .25s, box-shadow .25s;
    white-space: normal;
}
.han-ilce-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 24px rgba(255,115,0,.22);
    text-decoration: none;
    color: inherit;
}
.han-ilce-card__top {
    height: 78px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    color: rgba(255,255,255,.9);
}
/* 6 farklı gradient */
.han-scroll-track .han-ilce-card:nth-child(6n+1) .han-ilce-card__top { background: linear-gradient(135deg, #ff7300 0%, #1a1a2e 100%); }
.han-scroll-track .han-ilce-card:nth-child(6n+2) .han-ilce-card__top { background: linear-gradient(135deg, #1a1a2e 0%, #ff7300 100%); }
.han-scroll-track .han-ilce-card:nth-child(6n+3) .han-ilce-card__top { background: linear-gradient(135deg, #e85d00 0%, #0f172a 100%); }
.han-scroll-track .han-ilce-card:nth-child(6n+4) .han-ilce-card__top { background: linear-gradient(135deg, #0f172a 0%, #e85d00 100%); }
.han-scroll-track .han-ilce-card:nth-child(6n+5) .han-ilce-card__top { background: linear-gradient(135deg, #cc5500 0%, #1e2d4f 100%); }
.han-scroll-track .han-ilce-card:nth-child(6n+6) .han-ilce-card__top { background: linear-gradient(135deg, #1e2d4f 0%, #cc5500 100%); }
.han-ilce-card__body { padding: 12px 14px 14px; }
.han-ilce-card__name {
    display: block;
    font-size: 14px;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 4px;
}
.han-ilce-card__sub {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 11px;
    color: #64748b;
    font-weight: 500;
}
.han-ilce-card__sub .han-arr { color: #ff7300; font-size: 15px; font-weight: 700; }

