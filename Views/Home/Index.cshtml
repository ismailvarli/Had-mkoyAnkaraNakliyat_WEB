@{
    ViewData["Title"] = "Hadımköy Ankara Nakliyat | İstanbul Ankara Arası Profesyonel Taşımacılık";
    ViewData["Description"] = "İstanbul ve Ankara arasında evden eve, ofis, çeyiz, fuar, ambar ve parsiyel taşımacılıkta 7/24 hizmet. Ücretsiz ekspertiz ve sürprizsiz fiyat Hadımköy Ankara Nakliyat’ta!";

    // --- SEO: DİNAMİK JSON-LD ŞEMALARI (Visual Studio Dostu) ---
    var homeSchema = @"{
      ""@context"": ""https://schema.org"",
      ""@type"": ""WebSite"",
      ""name"": ""Hadımköy Ankara Nakliyat"",
      ""url"": ""https://www.hadimkoyankaranakliyat.com/"",
      ""potentialAction"": {
        ""@type"": ""SearchAction"",
        ""target"": ""https://www.hadimkoyankaranakliyat.com/search?q={search_term_string}"",
        ""query-input"": ""required name=search_term_string""
      }
    }";

    var homeServiceSchema = @"{
      ""@context"": ""https://schema.org"",
      ""@type"": ""Service"",
      ""name"": ""İstanbul Ankara Nakliyat Hizmetleri"",
      ""provider"": { ""@type"": ""LocalBusiness"", ""name"": ""Hadımköy Ankara Nakliyat"" },
      ""areaServed"": [""İstanbul"", ""Ankara"", ""Türkiye""],
      ""description"": ""İstanbul ve Ankara merkezli, 81 ile sigortalı, asansörlü ve kurumsal evden eve nakliyat, ofis taşıma ve parsiyel yük taşımacılığı.""
    }";
}

@* JSON-LD Çıktıları *@
<script type="application/ld+json">@Html.Raw(homeSchema)</script>
<script type="application/ld+json">@Html.Raw(homeServiceSchema)</script>

<style>
    /* --- HIZ VE GÖRÜNÜM İÇİN OPTİMİZE EDİLMİŞ CSS --- */

    /* 1. ABOUT BÖLÜMÜ (Tır ve Kamyonet) */
    .about-one__img {
        position: relative;
        display: block !important;
        margin-top: 20px;
    }

    /* Temanın kutu zorlamalarını iptal ediyoruz */
    .about-one__img1,
    .about-one__img2-inner,
    .about-one__img2 {
        position: relative !important;
        display: block !important;
        background: transparent !important; /* Arka plan şeffaf */
        border: none !important; /* Kenarlık yok */
        box-shadow: none !important; /* Gölge yok */
        border-radius: 0 !important; /* Yuvarlama yok */
        overflow: visible !important; /* Resim taşabilir */
        aspect-ratio: auto !important; /* Oran zorlaması yok */
        height: auto !important;
        padding: 0 !important;
    }

        /* Gizli tema süslerini (beyaz kutuları) yok et */
        .about-one__img1::before, .about-one__img1::after,
        .about-one__img2::before, .about-one__img2::after,
        .about-one__img2-inner::before, .about-one__img2-inner::after,
        .about-one__img::before, .about-one__img::after {
            display: none !important;
            content: none !important;
            background: none !important;
        }

        /* Resimlerin doğal hali */
        .about-one__img1 img,
        .about-one__img2-inner img {
            width: auto !important;
            max-width: 100% !important;
            height: auto !important;
            display: block !important;
            object-fit: contain !important;
            background: transparent !important;
        }

    /* Küçük Kamyon Konumu */
    .about-one__img2 {
        position: absolute !important;
        bottom: -30px !important;
        right: -20px !important;
        z-index: 99 !important;
        width: 60% !important;
    }

    /* 2. FAQ BÖLÜMÜ (Forklift) */
    .faq-one__img,
    .faq-one__img-box {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        overflow: visible !important;
    }

        /* Forklift arkası temizliği */
        .faq-one__img::before, .faq-one__img::after,
        .faq-one__img-box::before, .faq-one__img-box::after {
            display: none !important;
        }

        .faq-one__img img {
            background: transparent !important;
            mix-blend-mode: normal !important;
        }

    /* Döner yazı rozeti */
    .about-one__circle-text {
        position: absolute;
        left: 0;
        bottom: 20px;
        z-index: 100;
        pointer-events: none;
    }

    /* MOBİL AYARLARI */
    @@media (max-width: 991.98px) {
        .about-one__img {
            margin-top: 30px !important;
            margin-bottom: 30px !important;
            text-align: center !important;
            display: block !important; /* Mobilde gizlenmesin */
        }
        /* Mobilde Tır ortada dursun */
        .about-one__img1 {
            display: inline-block !important;
            width: 100% !important;
        }

            .about-one__img1 img {
                max-height: 300px !important;
            }
        /* Mobilde kalabalık yapan diğer unsurları gizle */
        .about-one__img2,
        .about-one .shape1,
        .about-one .shape2,
        .about-one .shape3,
        .about-one__circle-text {
            display: none !important;
        }
    }
</style>

