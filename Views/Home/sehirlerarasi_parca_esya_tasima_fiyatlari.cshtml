        {
          ""@type"": ""Question"",
          ""name"": ""Şehirler arası parça eşya taşıma fiyatı nasıl hesaplanır?"",
          ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Fiyat; eşyanın toplam hacmi (m³), ağırlığı, taşınacak mesafe, kat ve asansör durumu ile özel paketleme gereksinimine göre hesaplanır. Fiyat hesaplama için bizi aramanız yeterlidir."" }
        },
        {
          ""@type"": ""Question"",
          ""name"": ""İstanbul Ankara arası parça eşya taşıma ne kadar?"",
          ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""İstanbul-Ankara arası parça eşya taşıma fiyatı; tek beyaz eşya için 1.500-2.500 TL, koltuk takımı için 2.000-3.500 TL, birkaç koli için 500-1.500 TL aralığında başlamaktadır."" }
        },
        {
          ""@type"": ""Question"",
          ""name"": ""Tam araç fiyatıyla parça eşya fiyatı arasındaki fark nedir?"",
          ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Tam araç kiralamada sabit bir ücret ödersiniz. Parça eşya taşımada ise yalnızca kullandığınız alan kadar ödersiniz. Az eşya için parça eşya taşıma %60-70 daha ekonomik olabilir."" }
        },
        {
          ""@type"": ""Question"",
          ""name"": ""Fiyata sigorta dahil mi?"",
          ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Temel taşıma sigortası fiyata dahildir. Yüksek değerli eşyalar için ek sigorta seçeneği sunulmaktadır."" }
        },
        {
          ""@type"": ""Question"",
          ""name"": ""Kat taşıması ücrete dahil mi?"",
          ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Zemin kat ve asansörlü taşımalar standart fiyata dahildir. Asansörsüz kat taşıması için kat başına ek ücret alınmaktadır. Önceden belirtmenizi öneririz."" }
        }
      ]
    }";
}
