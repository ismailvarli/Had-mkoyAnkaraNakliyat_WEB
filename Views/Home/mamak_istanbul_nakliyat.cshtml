@{
    ViewData["Title"] = "Mamak İstanbul Nakliyat | Doğu Ankara'nın Dinamik İlçesi Mamak'tan İstanbul'a Profesyonel Nakliyat";
    ViewData["Description"] = "Mamak'tan İstanbul'a güvenilir nakliyat! Üreğil, Hüseyingazi ve tüm Mamak mahallelerinden asansörlü, sigortalı ev taşıma. Uygun fiyat için hemen arayın.";
}
@{
    var ilce = "Mamak";

    var ilceIstanbulService = string.Format(@"{{
      ""@context"": ""https://schema.org"",
      ""@type"": ""Service"",
      ""serviceType"": ""Şehir İçi Nakliyat"",
      ""name"": ""{0} İstanbul Nakliyat - Profesyonel Ev Taşıma"",
      ""provider"": {{ ""@type"": ""LocalBusiness"", ""name"": ""Hadımköy Ankara Nakliyat"" }},
      ""areaServed"": {{ ""@type"": ""City"", ""name"": ""{0}, Ankara"" }},
      ""description"": ""{0} İstanbul nakliyat hizmeti ile {0} ilçesinden İstanbul'un tüm semtlerine asansörlü, sigortalı ve marangozlu evden eve nakliye."",
      ""aggregateRating"": {{
        ""@type"": ""AggregateRating"",
        ""ratingValue"": ""4.9"",
        ""bestRating"": ""5"",
        ""worstRating"": ""1"",
        ""reviewCount"": ""9""
      }}
    }}", ilce);

    var ilceIstanbulFaq = string.Format(@"{{
      ""@context"": ""https://schema.org"",
      ""@type"": ""FAQPage"",
      ""mainEntity"": [
        {{
          ""@type"": ""Question"",
          ""name"": ""{0} İstanbul nakliyat fiyatları neye göre belirleniyor?"",
          ""acceptedAnswer"": {{ ""@type"": ""Answer"", ""text"": ""{0} çıkışlı taşımalarda fiyatlar; eşya miktarınıza (1+1, 2+1), gidilecek mesafeye ve kat durumuna göre ücretsiz ekspertiz sonucu belirlenir."" }}
        }},
        {{
          ""@type"": ""Question"",
          ""name"": ""{0} ilçesinde asansörlü araç kullanıyor musunuz?"",
          ""acceptedAnswer"": {{ ""@type"": ""Answer"", ""text"": ""Evet, {0} bölgesindeki dar sokaklar ve yüksek girişler için uygun mobil asansörlerimizle eşyalarınızı hasarsız taşıyoruz."" }}
        }},
        {{
          ""@type"": ""Question"",
          ""name"": ""{0} ilçesinden İstanbul'a taşıma kaç günde tamamlanır?"",
          ""acceptedAnswer"": {{ ""@type"": ""Answer"", ""text"": ""{0} - İstanbul arası komple taşımalarda aynı gün yükleme ertesi gün teslim prensibini uyguluyoruz. Parsiyel gönderilerde 1-3 iş günü içinde teslim yapılır."" }}
        }}
      ]
    }}", ilce);
}

@* HTML Çıktısı *@
<script type="application/ld+json">@Html.Raw(ilceIstanbulService)</script>
<script type="application/ld+json">@Html.Raw(ilceIstanbulFaq)</script>

