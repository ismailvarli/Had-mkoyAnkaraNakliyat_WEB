@{
    ViewData["Title"] = "İstanbul Ankara Parça Eşya Taşıma | Şehirler Arası Az Eşya";
    ViewData["Description"] = "İstanbul'dan Ankara'ya parça eşya taşıma hizmetleri. Tek parça eşya, az eşya ve şehirler arası küçük çaplı taşımalarda uzman ekip, sigortalı taşıma.";
}
@{
    var faqJson = @"{
      ""@context"": ""https://schema.org"",
      ""@type"": ""FAQPage"",
      ""mainEntity"": [
        {
          ""@type"": ""Question"",
          ""name"": ""İstanbul'dan Ankara'ya parça eşya taşıma kaç günde teslim edilir?"",
          ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""İstanbul-Ankara güzergahında haftanın her günü sefer düzenliyoruz. Eşyalarınız genellikle 24-48 saat içinde teslim edilir."" }
        },
        {
          ""@type"": ""Question"",
          ""name"": ""İstanbul Ankara arası parça eşya taşıma fiyatı nedir?"",
          ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Fiyat eşyanın hacmi ve türüne göre değişir. Tek beyaz eşya için 1.500-2.500 TL, birkaç koli için 800-1.500 TL aralığında başlamaktadır. Kesin fiyat için bizi arayın."" }
        },
        {
          ""@type"": ""Question"",
          ""name"": ""Ankara'dan İstanbul'a da taşıma yapıyor musunuz?"",
          ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Evet. Hem İstanbul'dan Ankara'ya hem de Ankara'dan İstanbul'a parça eşya taşıma hizmeti veriyoruz."" }
        },
        {
          ""@type"": ""Question"",
          ""name"": ""Kırılgan eşyaları güvenli taşıyor musunuz?"",
          ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Evet. Cam, ayna, tablo veya elektronik gibi kırılgan eşyalar özel balonlu naylon, nakliye battaniyesi ve ahşap kasalarla paketlenerek taşınır."" }
        },
        {
          ""@type"": ""Question"",
          ""name"": ""Kapıdan kapıya servis var mı?"",
          ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Evet. İstanbul'daki adresinizden alıp Ankara'daki adresinize teslim ediyoruz. Kat farkı ve asansörsüz taşıma için önceden bilgi almanızı öneririz."" }
        }
      ]
    }";

    var serviceJson = @"{
      ""@context"": ""https://schema.org"",
      ""@type"": ""Service"",
      ""serviceType"": ""İstanbul Ankara Parça Eşya Taşıma"",
      ""name"": ""İstanbul Ankara Arası Parça Eşya ve Az Eşya Taşıma"",
      ""provider"": { ""@type"": ""LocalBusiness"", ""name"": ""Hadımköy Ankara Nakliyat"", ""telephone"": ""+905344300360"" },
      ""areaServed"": [""İstanbul"", ""Ankara""],
      ""description"": ""İstanbul'dan Ankara'ya ve Ankara'dan İstanbul'a parça eşya, tek parça eşya ve az eşya taşıma hizmeti.""
    }";
}
<script type="application/ld+json">@Html.Raw(faqJson)</script>
<script type="application/ld+json">@Html.Raw(serviceJson)</script>

