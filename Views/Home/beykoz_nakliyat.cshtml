        padding: 8px 15px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }

    /* İçerik Kutuları */
    .intro-box {
        background: #f0fcf4;
        border-left: 5px solid var(--accent-forest);
        padding: 20px;
        font-size: 1.1em;
        line-height: 1.6;
        color: #444;
        margin-bottom: 30px;
        border-radius: 0 8px 8px 0;
