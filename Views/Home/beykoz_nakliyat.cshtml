@{
    Layout = "_Layout";
    ViewData["Title"] = "Beykoz Nakliyat | Villa ve Lüks Eşya Taşıma Uzmanı";
    ViewData["Description"] = "Beykoz'dan sigortalı evden eve nakliyat. Acarkent, Kavacık ve Beykoz Konakları bölgesinde villa taşıma, piyano nakliyesi ve kurumsal ofis çözümleri.";
}
@{
    // Sadece burayı değiştirmen yeterli! (Örn: "Beşiktaş", "Çatalca", "Arnavutköy")
    var ilce = "Beykoz";

    // Dinamik JSON-LD Hazırlığı
    // DÜZELTME: "adalar" yazan yerleri {0} yaptık. Artık yukarıdaki değişken neyse o gelecek.
    var ilceServiceJson = string.Format(@"{{
      ""@context"": ""https://schema.org"",
      ""@type"": ""Service"",
      ""serviceType"": ""Evden Eve Nakliyat"",
      ""name"": ""{0} Nakliyat - İstanbul Ankara Arası Güvenli Taşıma"",
      ""provider"": {{ ""@type"": ""LocalBusiness"", ""name"": ""Hadımköy Ankara Nakliyat"" }},
      ""areaServed"": {{ ""@type"": ""City"", ""name"": ""{0}, İstanbul"" }},
      ""description"": ""{0} bölgesinden Ankara'ya sigortalı, asansörlü ve marangozlu evden eve nakliyat hizmeti. Eşyalarınız profesyonel ekiplerle taşınır."",
      ""aggregateRating"": {{
        ""@@type"": ""AggregateRating"",
        ""ratingValue"": ""4.9"",
        ""bestRating"": ""5"",
        ""worstRating"": ""1"",
        ""reviewCount"": ""200""
      }}
    }}", ilce);

    var ilceFaqJson = string.Format(@"{{
      ""@context"": ""https://schema.org"",
      ""@type"": ""FAQPage"",
      ""mainEntity"": [
        {{
          ""@type"": ""Question"",
          ""name"": ""{0}'dan Ankara'ya taşınma kaç gün sürer?"",
          ""acceptedAnswer"": {{ ""@type"": ""Answer"", ""text"": ""Komple ev taşımalarında aynı gün yükleme, ertesi gün teslim prensibini uyguluyoruz. {0} ile Ankara arası 450-500 km olup araç ortalama 5-7 saatte varış adresine ulaşır. Parsiyel gönderilerde en yakın sefere göre 1-3 iş günü içinde teslim yapılır."" }}
        }},
        {{
          ""@type"": ""Question"",
          ""name"": ""{0} nakliyat fiyatları 2026'da ne kadar?"",
          ""acceptedAnswer"": {{ ""@type"": ""Answer"", ""text"": ""1+1 daire için 8.000-14.000 TL, 2+1 daire için 12.000-20.000 TL, 3+1 daire için 18.000-28.000 TL aralığında başlamaktadır. Kesin fiyat; kat sayısı, asansör durumu ve paketleme kapsamına göre ücretsiz keşif sonrasında yazılı olarak netleşir."" }}
        }},
        {{
          ""@type"": ""Question"",
          ""name"": ""Eşyalarım sigortalı taşınır mı?"",
          ""acceptedAnswer"": {{ ""@type"": ""Answer"", ""text"": ""Evet. Tüm taşımalarda nakliyat sigortası standarttır. Hasar durumunda sigorta şirketi devreye girer; tazminat hakkınız yazılı sözleşmeyle güvence altına alınır. Sigortasız taşıma yapmıyoruz."" }}
        }},
        {{
          ""@type"": ""Question"",
          ""name"": ""{0} nakliyat için ne kadar önceden rezervasyon yapmalıyım?"",
          ""acceptedAnswer"": {{ ""@type"": ""Answer"", ""text"": ""Yoğun dönemlerde (ay başı-sonu, bayram haftaları) en az 1 hafta önceden, normal dönemlerde 2-3 gün önce haber vermeniz yeterlidir. Acil taşımalarda aynı gün hizmet verebildiğimiz de olmaktadır."" }}
        }}
]
    }}", ilce);
}

@* HTML Çıktısı *@
<script type="application/ld+json">@Html.Raw(ilceServiceJson)</script>
<script type="application/ld+json">@Html.Raw(ilceFaqJson)</script>
<script type="application/ld+json">
{
  "@@context": "https://schema.org",
  "@@type": "BreadcrumbList",
  "itemListElement": [
    { "@@type": "ListItem", "position": 1, "name": "Ana Sayfa", "item": "https://www.hadimkoyankaranakliyat.com/" },
    { "@@type": "ListItem", "position": 2, "name": "Beykoz Nakliyat", "item": "https://www.hadimkoyankaranakliyat.com/beykoz-nakliyat" }
  ]
}
</script>

<style>
    :root {
        --primary-color: #d35400; /* Kurumsal Turuncu */
        --secondary-color: #2c3e50; /* Koyu Lacivert */
        --accent-forest: #27ae60; /* Beykoz Yeşili */
    }

    /* GENEL SAYFA YAPISI */
    .page-container {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 40px;
        max-width: 1200px;
        margin: 40px auto;
        padding: 0 20px;
        font-family: 'Segoe UI', sans-serif;
    }

    /* SOL MENÜ (SIDEBAR) - GÜNCEL FORMAT */
