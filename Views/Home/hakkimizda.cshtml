<script>
    $(function() {
        // SLIDER’I BAŞLAT
        $("#slider-range").slider({
            range: true,
            min: 0,
            max: 1000,
            values: [100, 500],
            slide: function(event, ui) {
                // Burada formda hidden input’a ve min-max kutularına değer atıyoruz
                $("#agirlikDegeri").val(ui.values[0] + "-" + ui.values[1]);
                $(".min").val(ui.values[0]);
                $(".max").val(ui.values[1]);
            }
        });
        // Sayfa açıldığında default değerleri ata
        $(".min").val($("#slider-range").slider("values", 0));
        $(".max").val($("#slider-range").slider("values", 1));
        $("#agirlikDegeri").val($("#slider-range").slider("values", 0) + "-" + $("#slider-range").slider("values", 1));
    });
</script>