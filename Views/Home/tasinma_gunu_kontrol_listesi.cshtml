@{
    ViewData["Title"] = "Taşınma Günü Kontrol Listesi: Hiçbir Şeyi Unutmayın";
    ViewData["Description"] = "Taşınma günü için eksiksiz kontrol listesi. 1 hafta öncesinden teslim anına kadar tüm adımlar. Hiçbir detayı atlamadan stressiz taşının.";
}
@{
    var howToJson = @"{
      ""@context"": ""https://schema.org"",
      ""@type"": ""HowTo"",
      ""name"": ""Taşınma Günü Kontrol Listesi: Adım Adım Rehber"",
      ""description"": ""Ev taşınma günü için eksiksiz adım adım kontrol listesi. 1 hafta öncesinden yeni evde yerleşime kadar tüm aşamalar."",
      ""totalTime"": ""P7D"",
      ""step"": [
        {
          ""@type"": ""HowToStep"",
          ""position"": 1,
          ""name"": ""1 Hafta Önce: Hazırlık ve Organizasyon"",
          ""text"": ""Tüm eşyaların listesini çıkarın, koli ve paketleme malzemeleri temin edin, nakliyat firmasını onaylayın, yeni evin kapı ve asansör ölçülerini alın, banka ve abonelikler için adres değişikliği yapın.""
        },
        {
          ""@type"": ""HowToStep"",
          ""position"": 2,
          ""name"": ""1 Gün Önce: Son Paketleme ve Kontrol"",
          ""text"": ""Tüm kolileri kapatıp bantlayın ve etiketleyin. Kırılgan kolilere KIRILGAN yazın. Değerli eşyaları ayrı çantaya alın. Buzdolabını boşaltıp kapatın. Nakliyat firmasını arayarak saati teyit edin.""
        },
        {
          ""@type"": ""HowToStep"",
          ""position"": 3,
          ""name"": ""Taşınma Sabahı: Ekip Gelmeden Önce"",
          ""text"": ""Ekipten en az 1 saat önce hazır olun. Apartman önü ve asansörü serbest bırakın. Yöneticiyi haberdar edin. Eşya listenizi yanınıza alın. Kırılgan eşyaları ayrı bir yerde ekibe gösterecek şekilde hazırlayın.""
        },
        {
          ""@type"": ""HowToStep"",
          ""position"": 4,
          ""name"": ""Yükleme Sırasında: Ekiple Koordinasyon"",
          ""text"": ""Kırılgan eşyaları ekibe gösterin. Tüm odaların tamamlandığını kontrol edin. Son koli yüklenene kadar evden çıkmayın. Tüm dolap içlerini, balkon ve depoyu son kez gözden geçirin. Su ve gaz vanasını kapatın.""
        },
        {
          ""@type"": ""HowToStep"",
          ""position"": 5,
          ""name"": ""Yeni Evde: Teslim Alma ve Yerleşim"",
          ""text"": ""Su, elektrik ve doğalgaz çalışıyor mu kontrol edin. Eşya listesiyle karşılaştırarak tüm kolilerin geldiğini teyit edin. Kırılgan eşyaları açıp hasar olup olmadığını kontrol edin. Hasar varsa fotoğraflayıp nakliyat firmasına bildirin.""
        }
      ]
    }";

    var faqJson = @"{
      ""@context"": ""https://schema.org"",
      ""@type"": ""FAQPage"",
      ""mainEntity"": [
        { ""@type"": ""Question"", ""name"": ""Taşınma günü ne zaman hazır olunmalı?"", ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Nakliyat ekibi gelmeden en az 1 saat önce hazır olun. Tüm kolilerin paketlenmiş, etiketlenmiş ve odaya göre gruplanmış olması gerekir."" } },
        { ""@type"": ""Question"", ""name"": ""Taşınma günü nakliyat ekibine ne söylemeli?"", ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Kırılgan eşyaları gösterin, hangi eşyanın önce taşınacağını belirtin, asansör veya dar merdiven gibi özel durumları bildirin ve teslim adresi için net yönlendirme yapın."" } },
        { ""@type"": ""Question"", ""name"": ""Yeni evde ilk ne yapmalıyım?"", ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Önce su, elektrik ve doğalgaz sayaçlarını kontrol edin. Ardından eşyaların tamamının gelip gelmediğini listeyle kontrol edin. Son olarak kırılgan eşyaları ve hasar varsa tespit edin."" } },
        { ""@type"": ""Question"", ""name"": ""Taşınmadan önce adres değişikliği ne zaman yapılmalı?"", ""acceptedAnswer"": { ""@type"": ""Answer"", ""text"": ""Taşınmadan en az 1 hafta önce banka, SGK, e-devlet ve abonelikler (elektrik, doğalgaz, internet) için adres değişikliği yapın."" } }
      ]
    }";
}
<script type="application/ld+json">@Html.Raw(howToJson)</script>
<script type="application/ld+json">@Html.Raw(faqJson)</script>

