<script>
  // Baz fiyatlar (TL)
  var BASE = {
    "1+1": 9000,
    "2+1": 15000,
    "3+1": 22000,
    "4+1": 30000,
    "Villa": 40000,
    "Parsiyel": 3000
  };

  // Rota çarpanı
  var ROUTE = {
    "istanbul-ankara": 1.0,
    "istanbul-ici": 0.35
  };

  // Kat ek ücreti (asansör yoksa)
  function katEk(kat, asansor) {
    if (asansor === "var") return 0;
    var ekler = { "zemin": 0, "1-3": 500, "4-6": 1200, "7+": 2000 };
    return ekler[kat] || 0;
  }

  function formatTL(sayi) {
    return "₺" + sayi.toLocaleString("tr-TR");
  }

  function hesapla() {
    var nereden = document.getElementById("nereden").value;
    var nereye  = document.getElementById("nereye").value;
    var evTipiEl = document.querySelector('input[name="evTipi"]:checked');
    var kat     = document.getElementById("kat").value;
    var asansorEl = document.querySelector('input[name="asansor"]:checked');
    var paketleme = document.getElementById("paketleme").checked;
    var marangoz  = document.getElementById("marangoz").checked;

    // Validasyon
    if (!nereden) {
      alert("Lütfen 'Nereden?' ilçesini seçin.");
      return;
    }
    if (!nereye) {
      alert("Lütfen 'Nereye?' hedefini seçin.");
      return;
    }
    if (!evTipiEl) {
      alert("Lütfen ev tipini seçin.");
      return;
    }

    var evTipi = evTipiEl.value;
    var asansor = asansorEl ? asansorEl.value : "var";

    var base = BASE[evTipi];
    var rota = (nereye === "istanbul-ici") ? ROUTE["istanbul-ici"] : ROUTE["istanbul-ankara"];
    base = Math.round(base * rota);
    base += katEk(kat, asansor);
    if (paketleme) base = Math.round(base * 1.15);
    if (marangoz) base += 500;

    var min = Math.round(base * 0.9 / 100) * 100;
    var max = Math.round(base * 1.2 / 100) * 100;

    // Detay metni
    var detaylar = [];
    if (rota === ROUTE["istanbul-ici"]) detaylar.push("Şehir içi taşıma");
    else detaylar.push("İstanbul → Ankara güzergahı");
    if (asansor === "yok" && katEk(kat, "yok") > 0) detaylar.push("Asansörsüz kat eki dahil");
    if (paketleme) detaylar.push("Profesyonel paketleme dahil");
    if (marangoz) detaylar.push("Demontaj/montaj dahil");

    document.getElementById("priceDisplay").textContent = formatTL(min) + " – " + formatTL(max);
    document.getElementById("detayBilgi").textContent = detaylar.join(" · ");

    var emptyState = document.getElementById("emptyState");
    var resultPanel = document.getElementById("resultPanel");
    emptyState.style.display = "none";
    resultPanel.classList.add("visible");
  }

  function toggleFaq(btn) {
    var answer = btn.nextElementSibling;
    var isOpen = answer.classList.contains("open");
    // Tümünü kapat
    document.querySelectorAll(".faq-answer.open").forEach(function(a) { a.classList.remove("open"); });
    document.querySelectorAll(".faq-question.open").forEach(function(b) { b.classList.remove("open"); });
    // Tıklananı aç (eğer kapalıysa)
    if (!isOpen) {
      answer.classList.add("open");
      btn.classList.add("open");
    }
  }
</script>
