    <script>
        function gtag_report_conversion(url) {
          try {
            if (typeof gtag === 'function') {
              var callback = function () { if (url) window.location = url; };
              gtag('event', 'conversion', {
                'send_to': 'AW-17507094342/B1I8CI3qs40bEMaehJxB',
                'value': 1.0,
                'currency': 'TRY',
                'event_callback': callback
              });
              // Ek güvenlik: 1 sn içinde callback gelmezse yine ara
              setTimeout(function(){ if (url) window.location = url; }, 1000);
              return false;
            }
          } catch(e) { /* yut */ }
          if (url) window.location = url; // gtag yoksa direkt ara
          return false;
        }

        document.addEventListener('DOMContentLoaded', function () {
          document.querySelectorAll('a[href^="tel:+905344300360"]').forEach(function (el) {
            el.addEventListener('click', function (e) {
              e.preventDefault();
              gtag_report_conversion(this.getAttribute('href'));
            });
          });
        });
    </script>
