    <!-- Google tag (gtag.js) – TEK KEZ -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17507094342"></script>
    <script>
        // 1) DataLayer
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }

        // 2) Consent varsayılanı (çerez banner'ın yoksa böyle kalsın)
        //   Banner kullanırsan buton onayında:
        //   gtag('consent','update',{ ad_storage:'granted', analytics_storage:'granted' });
        gtag('consent', 'default', {
          'ad_storage': 'granted',
          'analytics_storage': 'granted'
        });

        // 3) Başlatma
        gtag('js', new Date());

        // 4) Google Ads yapılandırma (AW satırı ŞART)
        gtag('config', 'AW-17507094342');

        // 5) Google Analytics 4
        gtag('config', 'G-3EDPZXCZ3Q');
    </script>

