    <style>
        /* Eski büyük butonlar varsa gizle */
        .call-now-btn, .whatsapp-btn {
            display: none !important;
        }

        :root {
            --fab-size: 56px;
            --fab-gap: 12px;
        }

        .fab-stack {
            position: fixed;
            right: max(16px, env(safe-area-inset-right));
            bottom: max(16px, env(safe-area-inset-bottom));
            z-index: 10000; /* scroll-to-top’tan yüksek */
            display: flex;
            flex-direction: column; /* üst üste */
            gap: var(--fab-gap);
            pointer-events: none; /* dışarıyı tıklanabilir bırak */
        }

            .fab-stack .fab {
                pointer-events: auto; /* sadece butonlar tıklanabilir */
                width: var(--fab-size);
                height: var(--fab-size);
                border-radius: 9999px;
                display: grid;
                place-items: center;
                color: #fff;
                text-decoration: none;
                box-shadow: 0 8px 24px rgba(0,0,0,.18);
                transform: translateZ(0);
                transition: transform .15s ease, filter .15s ease, box-shadow .15s ease;
            }

        .fab:hover {
            transform: scale(1.06);
            filter: brightness(.96);
            box-shadow: 0 10px 28px rgba(0,0,0,.22);
        }

        .fab-wa {
            background: #25D366;
        }

        .fab-call {
            background: #ff7300;
        }

        /* Varsayılan sayfa başlığı kapak fotoğrafı */
        .page-header__bg {
            background-image: url(‘/assets/images/gallery/HAN_1920x500_Ta%C5%9F%C4%B1mac%C4%B1l%C4%B1k.png’);
        }

        /* İlgili Hizmetler Bloğu (ilçe sayfaları) */
        .han-services-grid {
            background: linear-gradient(135deg, #0e1d2a 0%, #122535 100%);
            border-radius: 12px;
            padding: 28px 30px 24px;
            margin: 32px 0;
            border-top: 3px solid #ff7300;
        }
        .han-services-title {
            color: #ffffff;
            font-size: 18px;
            font-weight: 700;
            margin: 0 0 18px 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .han-services-icon { font-size: 22px; }
        .han-services-cards {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }
        .han-scard {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,115,0,0.25);
            border-radius: 8px;
            padding: 11px 14px;
            color: #e8e8e8;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: background 0.2s, border-color 0.2s, color 0.2s;
        }
        .han-scard:hover {
            background: rgba(255,115,0,0.18);
            border-color: #ff7300;
            color: #ff7300;
        }
        .han-scard-cta {
            background: rgba(255,115,0,0.15);
            border-color: rgba(255,115,0,0.5);
            color: #ffb070;
        }
        .han-scard-cta:hover {
            background: rgba(255,115,0,0.3);
            border-color: #ff7300;
            color: #ff7300;
        }
        .han-scard-icon { font-size: 16px; flex-shrink: 0; }
        @@media (max-width: 600px) {
            .han-services-cards { grid-template-columns: repeat(2, 1fr); }
            .han-services-grid { padding: 20px 16px; }
        }

        /* Scroll-to-top’ı butonların üstüne taşı */
        .scroll-to-top, .scroll-to-target {
            right: max(16px, env(safe-area-inset-right)) !important;
            bottom: calc( max(16px, env(safe-area-inset-bottom)) + var(--fab-size) + var(--fab-gap) + var(--fab-size) + 16px ) !important;
            z-index: 9998 !important;
        }

        /* Mobilde biraz küçült */
        @@media (max-width: 600px) {
            :root {
                --fab-size: 52px;
                --fab-gap: 10px;
            }
        }
    </style>


</head>

